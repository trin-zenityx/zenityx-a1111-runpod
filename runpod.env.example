# Full profile mirrors the Colab model bundle. Use "lite" for a faster first test.
ZENITYX_PROFILE=colab

# sd15-v2 | sd15-v2-thai | sd15-legacy | sdxl | default
ZENITYX_CONFIG_PRESET=sd15-v2

# Main public templates use short-lived No Login mode. Set WEBUI_AUTH=1 and use
# a RunPod Secret for WEBUI_PASSWORD if authentication is needed.
WEBUI_USERNAME=zenityx
# WEBUI_PASSWORD=
WEBUI_AUTH=0
ENABLE_API=0

# Optional UI language. Leave empty for the preset default; use th_TH for Thai.
UI_LANGUAGE=

# Optional extensions from the old Colab. Enabling one may add startup time.
EXT_ANIMATEDIFF=0
EXT_PROMPT_ALL_IN_ONE=0
EXT_WILDCARDS=0
EXT_REACTOR_SFW=0
EXT_REMBG=0
EXT_LORA_BLOCK_WEIGHT=0
EXT_COLOR_CORRECTION=0
EXT_MOV2MOV=0
EXT_WD14_TAGGER=0

# Reapply a preset over existing config only when intentionally resetting it.
FORCE_PRESET=0

# Extra A1111 flags, split on spaces. Leave empty for the safe defaults.
WEBUI_EXTRA_ARGS=
